{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "publish (win-x64)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "-c",
                "Release",
                "-o",
                "publish\\win-x64",
                "-r",
                "win-x64",
                "/p:DefineConstants=WINDOWS",
                "/p:NativeLib=Shared",
                "/p:SelfContained=true"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "publish (osx-arm64)",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/scripts"
            },
            "command": "bash",
            "args": [
                "build-osx-arm64.sh"
            ]
        },
        {
            "label": "publish (osx-x64)",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/scripts"
            },
            "command": "bash",
            "args": [
                "build-osx-x64.sh"
            ]
        },
        {
            "label": "publish (macos-universal)",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/scripts"
            },
            "command": "bash",
            "args": [
                "build-macos-universal.sh"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "publish and release (macos-universal)",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/scripts"
            },
            "command": "bash",
            "args": [
                "release-macos-universal.sh"
            ],
            "dependsOrder": "sequence",
            "dependsOn": [
                "publish (macos-universal)"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish and release (WSL linux-x64)",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/scripts/wsl"
            },
            "command": "powershell.exe",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                ".\\build-linux-x64-wsl.ps1"
            ]
        },
        {
            "label": "test (win-x64)",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/scripts"
            },
            "command": ".\\test.local.cmd"
        },
        {
            "label": "publish and test (win-x64)",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/scripts"
            },
            "command": ".\\test.local.cmd",
            "dependsOrder": "sequence",
            "dependsOn": [
                "publish (win-x64)"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish and release (win-x64)",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/scripts"
            },
            "command": ".\\release-win-x64.cmd",
            "dependsOrder": "sequence",
            "dependsOn": [
                "publish (win-x64)"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test (osx-local)",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/scripts"
            },
            "command": "bash",
            "args": [
                "test-osx-local.sh"
            ]
        },
        {
            "label": "Build win-x64 Installer",
            "type": "shell",
            "command": "makensis",
            "args": [
                "/V3",
                "scripts\\xObsAsyncImageSource-Installer.nsi"
            ],
            "group": "build"
        },
        {
            "label": "Build win-x64 Installer (strict)",
            "type": "shell",
            "command": "makensis",
            "args": [
                "/V3",
                "/WX",
                "scripts\\xObsAsyncImageSource-Installer.nsi"
            ],
            "group": "build"
        }
    ]
}